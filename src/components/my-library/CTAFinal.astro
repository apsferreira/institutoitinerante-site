---
// CTAFinal.astro — CTA final da LP Libri
import ContactForm from '../ContactForm.astro';
---

<section class="py-24 bg-gradient-to-br from-gray-900 via-amber-950 to-rose-950 ml-section relative overflow-hidden">
  <!-- Decorative books silhouettes -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden opacity-10">
    <div class="absolute bottom-0 left-1/4 flex gap-1 items-end">
      {['h-32 bg-amber-400', 'h-24 bg-rose-400', 'h-40 bg-teal-400', 'h-28 bg-purple-400', 'h-36 bg-orange-400'].map(c => (
        <div class={`w-8 ${c} rounded-t-sm`}></div>
      ))}
    </div>
    <div class="absolute bottom-0 right-1/4 flex gap-1 items-end">
      {['h-20 bg-blue-400', 'h-44 bg-amber-500', 'h-28 bg-green-400', 'h-36 bg-rose-500', 'h-24 bg-indigo-400'].map(c => (
        <div class={`w-8 ${c} rounded-t-sm`}></div>
      ))}
    </div>
  </div>

  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      
      <!-- Texto CTA -->
      <div class="text-center lg:text-left space-y-6">
        <div class="ml-reveal space-y-5">
          <span class="text-5xl">📚</span>
          <h2 class="text-3xl sm:text-4xl font-bold text-white leading-tight">
            Sua estante está esperando.
          </h2>
          <p class="text-lg text-white/70 leading-relaxed">
            Cada livro que você folheou, cada história que te transformou — eles merecem um lugar bonito para existir. Comece a construir sua biblioteca digital hoje mesmo.
          </p>
          <p class="text-white/50 text-sm">
            ✓ Gratuito para começar &nbsp;·&nbsp; ✓ Sem cartão de crédito &nbsp;·&nbsp; ✓ Cancele quando quiser
          </p>
        </div>
      </div>

      <!-- Formulário -->
      <div class="ml-reveal bg-white/10 backdrop-blur-lg rounded-2xl p-8 border border-white/20">
        <div class="text-center mb-6">
          <h3 class="text-xl font-bold text-white mb-2">Quero testar o Libri!</h3>
          <p class="text-white/70 text-sm">Deixe seus dados e te enviaremos o acesso antecipado</p>
        </div>
        
        <ContactForm product="libri" className="space-y-4" />
      </div>
      
    </div>
  </div>
</section>
