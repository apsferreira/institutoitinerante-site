---
// PricingSection.astro — Preços Free + Pago (API-driven with fallback)
import { fetchProductsWithPrices, formatPrice } from '../../lib/catalog';

// ── Fetch price from API ───────────────────────────────────────────────
let priceDisplay = 'R$ 19';
let yearlyDisplay = 'R$ 190/ano (economize 2 meses)';

const products = await fetchProductsWithPrices('plan');
const acervo = products.find((p) => p.name === 'Acervo Pro');

if (acervo && acervo.prices.length > 0) {
  const monthly = acervo.prices.find((pr) => pr.interval === 'monthly');
  const yearly = acervo.prices.find((pr) => pr.interval === 'yearly');

  if (monthly) {
    priceDisplay = formatPrice(monthly.amount_cents);
  }
  if (yearly) {
    yearlyDisplay = `${formatPrice(yearly.amount_cents)}/ano (economize 2 meses)`;
  }
}
---

<section id="precos" class="py-20 bg-white ml-section">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14 ml-reveal space-y-3">
      <span class="inline-block bg-amber-100 text-amber-700 text-xs font-semibold px-3 py-1 rounded-full uppercase tracking-wider">Planos</span>
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">Comece de graça. Evolua quando quiser.</h2>
      <p class="text-gray-600 text-lg max-w-xl mx-auto">Sem pressão, sem urgência. Sua biblioteca já vale a pena no plano gratuito.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-3xl mx-auto">

      <!-- Plano Free -->
      <div class="ml-reveal bg-amber-50 border-2 border-amber-200 rounded-2xl p-8 space-y-6">
        <div>
          <h3 class="text-xl font-bold text-gray-900">Gratuito</h3>
          <p class="text-gray-500 text-sm mt-1">Para começar a organizar sua biblioteca</p>
          <div class="mt-4">
            <span class="text-4xl font-bold text-gray-900">R$ 0</span>
            <span class="text-gray-500 text-sm">/mês · para sempre</span>
          </div>
        </div>

        <ul class="space-y-3 text-sm text-gray-700">
          {[
            '📚 Até 100 livros no catálogo',
            '🎨 Capas automáticas',
            '📈 Progresso de leitura',
            '🏷️ Prateleiras (lendo, lido, quero ler)',
            '📱 App web e mobile',
          ].map(item => (
            <li class="flex items-start gap-2">
              <span class="text-amber-500 mt-0.5 shrink-0">✓</span>
              {item}
            </li>
          ))}
          {[
            'Estatísticas anuais detalhadas',
            'Import/Export (Goodreads, CSV)',
            'Metas de leitura',
          ].map(item => (
            <li class="flex items-start gap-2 opacity-40">
              <span class="mt-0.5 shrink-0">✗</span>
              {item}
            </li>
          ))}
        </ul>

        <a
          href="https://app.mylibrary.com.br"
          class="block w-full text-center bg-white border-2 border-amber-400 text-amber-700 font-semibold px-6 py-3 rounded-xl hover:bg-amber-50 transition-colors"
        >
          Começar com minha biblioteca
        </a>
      </div>

      <!-- Plano Pago -->
      <div class="ml-reveal relative bg-gradient-to-br from-amber-500 to-rose-500 rounded-2xl p-8 space-y-6 text-white shadow-xl">
        <div class="absolute -top-3 left-1/2 -translate-x-1/2">
          <span class="bg-gray-900 text-white text-xs font-bold px-3 py-1 rounded-full">MAIS POPULAR</span>
        </div>

        <div>
          <h3 class="text-xl font-bold">Biblioteca Completa</h3>
          <p class="text-white/80 text-sm mt-1">Para leitores sérios sobre sua jornada</p>
          <div class="mt-4">
            <span class="text-4xl font-bold">{priceDisplay}</span>
            <span class="text-white/80 text-sm">/mês</span>
          </div>
          <p class="text-white/70 text-xs mt-1">ou {yearlyDisplay}</p>
        </div>

        <ul class="space-y-3 text-sm text-white">
          {[
            '📚 Livros ilimitados',
            '🎨 Capas automáticas',
            '📊 Estatísticas anuais completas',
            '🎯 Metas de leitura com acompanhamento',
            '🔄 Import do Goodreads (CSV)',
            '📤 Export da sua biblioteca',
            '🔒 Backup automático na nuvem',
            '⭐ Suporte prioritário',
          ].map(item => (
            <li class="flex items-start gap-2">
              <span class="mt-0.5 shrink-0 text-white">✓</span>
              {item}
            </li>
          ))}
        </ul>

        <a
          href="https://app.mylibrary.com.br/assinar"
          class="block w-full text-center bg-white text-amber-700 font-bold px-6 py-3 rounded-xl hover:bg-amber-50 transition-colors shadow-lg"
        >
          Desbloquear estatísticas completas
        </a>
        <p class="text-center text-white/70 text-xs">7 dias grátis · Cancele quando quiser</p>
      </div>

    </div>
  </div>
</section>
