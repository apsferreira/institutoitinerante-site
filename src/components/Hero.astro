---
interface Props {
  t: any;
}
const { t } = Astro.props;
---

<section class="hero-section hero-bg-anim relative min-h-screen flex items-center justify-center pt-16 overflow-hidden">
  <!-- Circuit grid background (CSS only) -->
  <div class="hero-grid absolute inset-0 pointer-events-none"></div>
  <!-- Glow blobs -->
  <div class="absolute top-1/3 right-1/4 w-96 h-96 bg-[#0097D6]/10 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-1/4 left-1/4 w-64 h-64 bg-[#00D6A0]/8 rounded-full blur-3xl pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 text-center">
    <!-- Logo principal -->
    <div class="flex justify-center mb-10 fade-in-up" style="animation-delay: 0s">
      <img
        src="/logo-iit-white.png"
        alt="Instituto Itinerante de Tecnologia"
        width="192"
        height="96"
        loading="eager"
        class="h-24 md:h-32 w-auto object-contain drop-shadow-2xl"
      />
    </div>

    <h1 class="text-5xl sm:text-6xl md:text-7xl font-black text-white leading-tight tracking-tight fade-in-up" style="animation-delay: 0.2s">
      Seu WhatsApp atendendo<br class="hidden sm:block" />
      <span style="color: #0097D6;">24h</span> sem contratar<br class="hidden sm:block" /> mais ninguém
    </h1>

    <!-- Typewriter de casos de uso -->
    <div class="mt-6 fade-in-up" style="animation-delay: 0.28s; min-height: 3.5rem;">
      <p class="text-xl md:text-2xl max-w-3xl mx-auto leading-relaxed" style="color: #8A9FAF;">
        Enquanto você descansa, o Attend-Agent está&nbsp;<span
          id="hero-typewriter"
          class="typewriter-text font-semibold"
          style="color: #0097D6;"
          aria-live="polite"
        >qualificando seus leads</span>
      </p>
    </div>

    <!-- Credibility bar -->
    <div class="mt-8 flex items-center justify-center gap-6 flex-wrap fade-in-up" style="animation-delay: 0.35s">
      <span class="text-sm text-gray-400 flex items-center gap-2"><span class="text-[#00D6A0]">⚡</span> Resposta em &lt; 30 segundos</span>
      <span class="text-gray-600">·</span>
      <span class="text-sm text-gray-400 flex items-center gap-2"><span class="text-[#00D6A0]">🕐</span> 24/7</span>
      <span class="text-gray-600">·</span>
      <span class="text-sm text-gray-400 flex items-center gap-2"><span class="text-[#00D6A0]">🛠️</span> Sem técnico para configurar</span>
    </div>

    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4 fade-in-up" style="animation-delay: 0.4s">
      <a
        href="https://wa.me/5571992732430"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-pulse btn-shimmer inline-flex items-center gap-2 bg-[#0097D6] hover:bg-[#007ab8] text-white font-bold px-8 py-4 rounded-xl text-base shadow-lg shadow-[#0097D6]/30 transition-all duration-200 hover:scale-105"
      >
        <svg class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        {t.hero.ctaPrimary}
      </a>
      <a href="#attend-agent" class="inline-flex items-center gap-2 border-2 border-white/30 text-white hover:border-[#0097D6] hover:text-[#0097D6] font-semibold px-8 py-4 rounded-xl text-base transition-all duration-200">
        {t.hero.ctaSecondary}
      </a>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </div>
  </div>
</section>

<style>
  .hero-section {
    background: linear-gradient(135deg, #080d11 0%, #0D1B26 40%, #0d2740 70%, #0D1B26 100%);
  }

  .hero-grid {
    background-image:
      linear-gradient(rgba(0, 151, 214, 0.07) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 151, 214, 0.07) 1px, transparent 1px);
    background-size: 40px 40px;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .fade-in-up {
    opacity: 0;
    animation: fadeInUp 0.6s ease forwards;
  }
</style>
