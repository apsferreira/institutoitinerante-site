---
interface Props {
  product: 'libri' | 'nitro' | 'pedeai' | 'fabricadefestas' | 'brio';
  ctaText?: string;
  className?: string;
}

const { product, ctaText, className = '' } = Astro.props;

const defaultCtaText = {
  libri: 'Quero testar',
  nitro: 'Começar agora',
  pedeai: 'Solicitar demonstração',
  fabricadefestas: 'Cadastrar meu negócio',
  brio: 'Falar com vendas',
};

const buttonText = ctaText || defaultCtaText[product];
---

<form 
  class={`contact-form ${className}`}
  data-product={product}
  novalidate
>
  <!-- Nome -->
  <div class="form-group mb-4">
    <label 
      for="name" 
      class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2"
    >
      Nome *
    </label>
    <input
      type="text"
      id="name"
      name="name"
      required
      placeholder="Seu nome completo"
      autocomplete="name"
      class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:text-white disabled:bg-gray-100 disabled:cursor-not-allowed transition-colors"
    />
  </div>

  <!-- Email -->
  <div class="form-group mb-4">
    <label 
      for="email" 
      class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2"
    >
      Email *
    </label>
    <input
      type="email"
      id="email"
      name="email"
      required
      placeholder="seu@email.com"
      autocomplete="email"
      class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:text-white disabled:bg-gray-100 disabled:cursor-not-allowed transition-colors"
    />
  </div>

  <!-- Telefone (opcional) -->
  <div class="form-group mb-4">
    <label 
      for="phone" 
      class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2"
    >
      Telefone (opcional)
    </label>
    <input
      type="tel"
      id="phone"
      name="phone"
      placeholder="(11) 99999-9999"
      autocomplete="tel"
      class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:text-white disabled:bg-gray-100 disabled:cursor-not-allowed transition-colors"
    />
  </div>

  <!-- Mensagem (opcional) -->
  <div class="form-group mb-6">
    <label 
      for="message" 
      class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2"
    >
      Mensagem (opcional)
    </label>
    <textarea
      id="message"
      name="message"
      placeholder="Como podemos ajudar?"
      rows="4"
      class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:text-white disabled:bg-gray-100 disabled:cursor-not-allowed resize-vertical transition-colors"
    ></textarea>
  </div>

  <!-- Feedback de erro -->
  <div class="error-message mb-4 p-3 bg-red-50 border border-red-200 rounded-lg hidden" role="alert">
    <div class="flex items-center">
      <svg class="h-5 w-5 text-red-400 mr-2 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
      </svg>
      <span class="text-red-800 text-sm error-text"></span>
    </div>
  </div>

  <!-- Feedback de sucesso -->
  <div class="success-message mb-4 p-3 bg-green-50 border border-green-200 rounded-lg hidden" role="alert">
    <div class="flex items-center">
      <svg class="h-5 w-5 text-green-400 mr-2 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
      </svg>
      <span class="text-green-800 text-sm">
        Mensagem enviada com sucesso! Entraremos em contato em breve.
      </span>
    </div>
  </div>

  <!-- Botão de envio -->
  <button
    type="submit"
    class="submit-btn w-full bg-[#0097D6] hover:bg-[#007ab8] disabled:bg-gray-400 text-white font-semibold py-4 px-6 rounded-lg transition duration-200 flex items-center justify-center gap-2 shadow-lg hover:shadow-xl transform hover:-translate-y-0.5"
  >
    <span class="btn-text">{buttonText}</span>
    
    <!-- Loading spinner -->
    <svg class="loading-spinner animate-spin -ml-1 mr-3 h-5 w-5 text-white hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
    </svg>
    
    <!-- Success checkmark -->
    <svg class="success-icon h-5 w-5 hidden" fill="currentColor" viewBox="0 0 20 20">
      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
    </svg>
  </button>

  <!-- Nota de privacidade -->
  <p class="mt-4 text-xs text-gray-500 dark:text-gray-400 text-center">
    Ao enviar este formulário, você concorda com nossa
    <a href="/privacidade" target="_blank" rel="noopener" class="text-[#0097D6] hover:text-[#007ab8] underline">
      Política de Privacidade
    </a>.
  </p>
</form>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const forms = document.querySelectorAll('.contact-form');
  
  forms.forEach(form => {
    const submitBtn = form.querySelector('.submit-btn');
    const btnText = form.querySelector('.btn-text');
    const loadingSpinner = form.querySelector('.loading-spinner');
    const successIcon = form.querySelector('.success-icon');
    const errorMessage = form.querySelector('.error-message');
    const successMessage = form.querySelector('.success-message');
    const errorText = form.querySelector('.error-text');
    
    const product = form.dataset.product;
    
    // Validação de email
    function isValidEmail(email) {
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      return emailRegex.test(email);
    }
    
    // Mostrar erro
    function showError(message) {
      errorText.textContent = message;
      errorMessage.classList.remove('hidden');
      successMessage.classList.add('hidden');
    }
    
    // Mostrar sucesso
    function showSuccess() {
      successMessage.classList.remove('hidden');
      errorMessage.classList.add('hidden');
    }
    
    // Esconder mensagens
    function hideMessages() {
      errorMessage.classList.add('hidden');
      successMessage.classList.add('hidden');
    }
    
    // Estados do botão
    function setLoadingState() {
      submitBtn.disabled = true;
      btnText.textContent = 'Enviando...';
      loadingSpinner.classList.remove('hidden');
      successIcon.classList.add('hidden');
    }
    
    function setSuccessState() {
      btnText.textContent = 'Enviado ✓';
      loadingSpinner.classList.add('hidden');
      successIcon.classList.remove('hidden');
    }
    
    function resetState() {
      submitBtn.disabled = false;
      btnText.textContent = form.querySelector('button').dataset.originalText;
      loadingSpinner.classList.add('hidden');
      successIcon.classList.add('hidden');
    }
    
    // Salvar texto original do botão
    submitBtn.dataset.originalText = btnText.textContent;
    
    // Limpar erro quando o usuário digitar
    form.addEventListener('input', hideMessages);
    
    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      
      const formData = new FormData(form);
      const name = formData.get('name').trim();
      const email = formData.get('email').trim();
      const phone = formData.get('phone').trim();
      const message = formData.get('message').trim();
      
      // Validação
      if (!name) {
        showError('Por favor, informe seu nome.');
        return;
      }
      
      if (!email) {
        showError('Por favor, informe seu email.');
        return;
      }
      
      if (!isValidEmail(email)) {
        showError('Por favor, informe um email válido.');
        return;
      }
      
      // Estado de loading
      hideMessages();
      setLoadingState();
      
      try {
        const response = await fetch('/api/v1/forms/lead', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            product: product,
            name: name,
            email: email,
            phone: phone || undefined,
            message: message || undefined,
          }),
        });
        
        if (!response.ok) {
          // Erros específicos
          if (response.status === 400) {
            const errorData = await response.json();
            throw new Error(errorData.message || 'Dados inválidos. Verifique os campos.');
          }
          if (response.status === 429) {
            throw new Error('Muitas tentativas. Aguarde alguns minutos e tente novamente.');
          }
          throw new Error('Erro ao enviar formulário. Tente novamente.');
        }
        
        // Sucesso!
        setSuccessState();
        showSuccess();
        
        // Limpar formulário
        form.reset();
        
        // Reset do botão após 3 segundos
        setTimeout(() => {
          resetState();
        }, 3000);
        
      } catch (error) {
        resetState();
        showError(error.message);
      }
    });
  });
});
</script>