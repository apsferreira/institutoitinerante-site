---
interface Props {
  t: any;
}
const { t } = Astro.props;

const stats = [
  { value: '16',   suffix: 'anos', label: 'de existência' },
  { value: '30+',  suffix: '',     label: 'jovens formados' },
  { value: '100+', suffix: '',     label: 'projetos entregues' },
  { value: '2030', suffix: '',     label: 'meta nacional' },
]

const pmv = [
  {
    icon: '🎯',
    label: 'Propósito',
    title: 'Democratizar o acesso à tecnologia',
    desc: 'Tornar a tecnologia de ponta acessível para PMEs brasileiras — sem barreiras de custo ou complexidade.',
    accent: '#0097D6',
  },
  {
    icon: '🚀',
    label: 'Missão',
    title: 'Impacto real, não promessas',
    desc: 'Desenvolver soluções que transformam negócios e geram oportunidades concretas para pessoas e comunidades.',
    accent: '#00D6A0',
  },
  {
    icon: '🔭',
    label: 'Visão',
    title: 'Referência em automação até 2030',
    desc: 'Ser a principal plataforma de automação inteligente para PMEs no Brasil — levando tecnologia de grande empresa para o interior do país.',
    accent: '#6366F1',
  },
]

const values = [
  { icon: '🔍', title: 'Transparência',              desc: 'Comunicação clara e honesta em cada etapa.' },
  { icon: '⭐', title: 'Qualidade',                  desc: 'Soluções robustas, bem construídas e com suporte real.' },
  { icon: '🌱', title: 'Inclusão digital',           desc: 'Tecnologia como ferramenta de empoderamento social.' },
  { icon: '🤝', title: 'Responsabilidade social',    desc: 'Cada projeto contribui para um futuro mais justo.' },
]
---

<section id="sobre" class="overflow-hidden">

  <!-- ── 1. Opening ────────────────────────────────────────────────── -->
  <div class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

        <!-- Texto -->
        <div class="reveal">
          <span class="inline-block text-sm font-semibold uppercase tracking-widest text-[#0097D6] mb-4">
            Quem somos
          </span>
          <h2 class="text-4xl md:text-5xl font-black text-[#0D1B26] leading-tight mb-6">
            Tecnologia que<br />
            <span class="text-[#0097D6]">transforma vidas</span>
          </h2>
          <p class="text-lg text-[#4B6070] leading-relaxed mb-5">
            O Instituto Itinerante de Tecnologia nasceu com um sonho claro: usar a tecnologia como ferramenta de inclusão e transformação social. Em 16 anos, formamos mais de 30 jovens egressos do ensino médio em comunidades de Salvador, abrindo portas reais de emprego e renda através do conhecimento técnico.
          </p>
          <p class="text-lg text-[#4B6070] leading-relaxed">
            Hoje, esse mesmo compromisso guia cada solução que desenvolvemos — da automação inteligente à IA aplicada. Porque acreditamos que quando a tecnologia chega a quem mais precisa, ela muda o mundo.
          </p>
        </div>

        <!-- Pull quote -->
        <div class="reveal reveal-delay-1">
          <div class="relative bg-[#0D1B26] rounded-2xl p-10 overflow-hidden">
            <!-- Detalhe decorativo -->
            <div class="absolute top-0 right-0 w-40 h-40 rounded-full opacity-10"
                 style="background: radial-gradient(circle, #0097D6, transparent); transform: translate(30%, -30%);"></div>
            <div class="absolute bottom-0 left-0 w-32 h-32 rounded-full opacity-10"
                 style="background: radial-gradient(circle, #00D6A0, transparent); transform: translate(-30%, 30%);"></div>

            <svg class="w-10 h-10 text-[#0097D6] mb-6 opacity-60" fill="currentColor" viewBox="0 0 24 24">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
            </svg>

            <blockquote class="text-xl md:text-2xl font-semibold text-white leading-relaxed mb-6">
              "Acreditamos que a tecnologia é um meio para empoderar pessoas e construir um futuro mais justo."
            </blockquote>

            <div class="flex items-center gap-3 pt-4 border-t border-white/10">
              <div class="w-10 h-10 rounded-full bg-[#0097D6] flex items-center justify-center shrink-0">
                <span class="text-white font-bold text-sm">IIT</span>
              </div>
              <div>
                <p class="text-white font-semibold text-sm">Instituto Itinerante de Tecnologia</p>
                <p class="text-white/50 text-xs">Salvador, Bahia — desde 2009</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ── 2. Números de impacto ──────────────────────────────────────── -->
  <div class="py-16" style="background: linear-gradient(135deg, #0097D6 0%, #006FA3 100%);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        {stats.map((s, i) => (
          <div class:list={['reveal', i > 0 && `reveal-delay-${i}`]}>
            <div class="flex items-end justify-center gap-1 mb-1">
              <span class="text-5xl font-black text-white">{s.value}</span>
              {s.suffix && <span class="text-xl font-bold text-white/70 mb-2">{s.suffix}</span>}
            </div>
            <p class="text-sm font-medium text-white/80 uppercase tracking-wider">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- ── 3. Propósito · Missão · Visão ─────────────────────────────── -->
  <div class="py-24 bg-[#F5F8FA]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14 reveal">
        <h3 class="text-3xl md:text-4xl font-black text-[#0D1B26] mb-3">Por que existimos</h3>
        <p class="text-[#4B6070] text-lg max-w-xl mx-auto">
          Nossa bússola estratégica — o que nos move, o que entregamos e onde queremos chegar.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {pmv.map((card, i) => (
          <div class:list={['reveal', i > 0 && `reveal-delay-${i}`, 'group bg-white rounded-2xl p-8 shadow-sm border border-gray-100 hover:shadow-xl transition-all duration-300 hover:-translate-y-1']}>
            <!-- Eyebrow + ícone -->
            <div class="flex items-center gap-3 mb-5">
              <div class="w-11 h-11 rounded-xl flex items-center justify-center text-2xl shrink-0"
                   style={`background: ${card.accent}15`}>
                {card.icon}
              </div>
              <span class="text-xs font-bold uppercase tracking-widest"
                    style={`color: ${card.accent}`}>
                {card.label}
              </span>
            </div>

            <!-- Título + descrição -->
            <h4 class="text-xl font-bold text-[#0D1B26] mb-3 leading-snug group-hover:text-[#0097D6] transition-colors">
              {card.title}
            </h4>
            <p class="text-[#4B6070] text-sm leading-relaxed">{card.desc}</p>

            <!-- Barra de acento no rodapé -->
            <div class="mt-6 h-0.5 w-0 group-hover:w-full transition-all duration-500 rounded-full"
                 style={`background: ${card.accent}`}></div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- ── 4. Valores ─────────────────────────────────────────────────── -->
  <div class="py-24 bg-[#0D1B26]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14 reveal">
        <span class="inline-block text-sm font-semibold uppercase tracking-widest text-[#0097D6] mb-3">
          Nossos valores
        </span>
        <h3 class="text-3xl md:text-4xl font-black text-white">Como trabalhamos</h3>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {values.map((v, i) => (
          <div class:list={['reveal', i > 0 && `reveal-delay-${i}`, 'group relative bg-white/5 hover:bg-[#0097D6]/10 border border-white/10 hover:border-[#0097D6]/40 rounded-2xl p-7 transition-all duration-300']}>
            <span class="text-3xl mb-4 block">{v.icon}</span>
            <h4 class="text-base font-bold text-white mb-2">{v.title}</h4>
            <p class="text-sm text-white/55 leading-relaxed">{v.desc}</p>
            <div class="absolute bottom-0 left-0 right-0 h-0.5 rounded-b-2xl bg-[#0097D6] opacity-0 group-hover:opacity-100 transition-opacity"></div>
          </div>
        ))}
      </div>
    </div>
  </div>

</section>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .reveal.revealed {
    opacity: 1;
    transform: translateY(0);
  }
  .reveal-delay-1 { transition-delay: 0.1s; }
  .reveal-delay-2 { transition-delay: 0.2s; }
  .reveal-delay-3 { transition-delay: 0.3s; }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed')
          observer.unobserve(entry.target)
        }
      })
    },
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' },
  )
  document.querySelectorAll('#sobre .reveal').forEach((el) => observer.observe(el))
</script>
