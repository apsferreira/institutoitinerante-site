---
interface Props {
  t: any;
}
const { t } = Astro.props;
---

<section id="sobre" class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto text-center mb-16">
      <span class="inline-block text-sm font-semibold uppercase tracking-widest mb-3" style="color: #0097D6;">{t.about.sectionLabel}</span>
      <h2 class="text-4xl font-black mb-6 section-accent-title">{t.about.title}</h2>
      <p class="text-lg leading-relaxed mt-6 max-w-2xl mx-auto" style="color: #4B6070;">
        {t.about.text}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {t.about.values.map((value: any) => (
        <div class="flex flex-col items-center text-center p-8 rounded-2xl bg-gray-50 hover:bg-blue-50 transition-all duration-300 hover:-translate-y-1 border border-gray-100">
          <span class="text-4xl mb-4">{value.icon}</span>
          <h3 class="text-xl font-bold mb-3" style="color: #0D1B26;">{value.title}</h3>
          <p class="leading-relaxed" style="color: #4B6070;">{value.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .section-accent-title {
    color: #0D1B26;
    position: relative;
    display: inline-block;
    padding-bottom: 12px;
  }
  .section-accent-title::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 60px;
    height: 4px;
    background: #0097D6;
    border-radius: 2px;
  }
</style>
