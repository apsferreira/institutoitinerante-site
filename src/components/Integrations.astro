---
interface Props {
  lang?: string;
}
const { lang = 'pt-BR' } = Astro.props;
const isEn = lang === 'en';

const integrations = [
  { name: 'WhatsApp Business', icon: '💬', color: '#25D366', desc: isEn ? 'Native integration' : 'Integração nativa' },
  { name: 'Google Agenda', icon: '📅', color: '#4285F4', desc: isEn ? 'Auto scheduling' : 'Agendamento automático' },
  { name: 'Calendly', icon: '🗓️', color: '#006BFF', desc: isEn ? 'Booking links' : 'Links de agendamento' },
  { name: 'Gemini AI', icon: '✨', color: '#8E24AA', desc: isEn ? 'Powered by Google AI' : 'Google AI embarcado' },
];
---

<section class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <span class="inline-block text-sm font-semibold uppercase tracking-widest mb-3 text-[#0097D6]">{isEn ? 'Integrations' : 'Integrações'}</span>
      <h2 class="text-4xl font-black text-[#0D1B26] mb-4 section-accent">
        {isEn ? 'Integrates with tools you already use' : 'Integra com as ferramentas que você já usa'}
      </h2>
      <p class="text-gray-500 max-w-lg mx-auto">
        {isEn ? 'No migration needed. Plug in, and go.' : 'Sem migração. Conecta e funciona.'}
      </p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
      {integrations.map((intg) => (
        <div class="border border-[#D0DDE6] shadow-sm hover:shadow-md hover:-translate-y-1 transition-all rounded-2xl p-6 text-center group">
          <div class="text-5xl mb-3">{intg.icon}</div>
          <p class="font-bold text-[#0D1B26] text-sm">{intg.name}</p>
          <p class="text-xs text-gray-500 mt-1">{intg.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .section-accent {
    position: relative;
    display: inline-block;
    padding-bottom: 12px;
  }
  .section-accent::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 60px;
    height: 4px;
    background: #0097D6;
    border-radius: 2px;
  }
</style>
