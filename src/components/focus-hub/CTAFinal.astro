---
// CTAFinal.astro — CTA final da landing page
import ContactForm from '../ContactForm.astro';
---

<section class="bg-gradient-to-br from-[#0A0F14] via-[#0D1B26] to-[#0A1F2E] py-28 relative overflow-hidden">
  <!-- Blobs decorativos -->
  <div class="absolute top-0 left-1/4 w-96 h-96 bg-[#0097D6]/8 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-0 right-1/4 w-80 h-80 bg-[#00D6A0]/8 rounded-full blur-3xl pointer-events-none"></div>

  <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      
      <!-- Texto CTA -->
      <div class="text-center lg:text-left fh-reveal">
        <!-- Ícone -->
        <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-[#0097D6] to-[#00D6A0] flex items-center justify-center mx-auto lg:mx-0 mb-8 shadow-2xl shadow-[#00D6A0]/20">
          <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
          </svg>
        </div>

        <h2 class="text-3xl sm:text-4xl font-black text-white leading-tight">
          Sua cabeça merece um descanso.
        </h2>
        <p class="mt-5 text-lg text-gray-300 leading-relaxed">
          Comece a capturar hoje — e termine o dia sabendo que fez o que importava. GTD simplificado que realmente funciona.
        </p>

        <p class="mt-6 text-gray-500 text-sm">
          ✓ Grátis para sempre &nbsp;·&nbsp; ✓ Sem cartão &nbsp;·&nbsp; ✓ Web + iOS + Android
        </p>

        <!-- Mini-depoimento -->
        <div class="mt-10 border-t border-white/10 pt-8">
          <p class="text-gray-300 text-base italic leading-relaxed">
            "Em 3 dias usando o Nitro, minha cabeça ficou mais leve do que em anos de tentativas com outros sistemas."
          </p>
          <div class="flex items-center justify-center lg:justify-start gap-2 mt-4">
            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-[#0097D6] to-[#00D6A0] flex items-center justify-center text-white font-bold text-xs">RA</div>
            <span class="text-gray-400 text-sm">Rodrigo Almeida · Consultor · São Paulo</span>
          </div>
        </div>
      </div>

      <!-- Formulário -->
      <div class="fh-reveal bg-white/5 backdrop-blur-lg rounded-2xl p-8 border border-white/10 shadow-2xl shadow-[#0097D6]/10">
        <div class="text-center mb-6">
          <h3 class="text-xl font-bold text-white mb-2">Começar com Nitro</h3>
          <p class="text-gray-300 text-sm">Deixe seus dados e receba acesso antecipado ao beta</p>
        </div>
        
        <ContactForm product="nitro" className="space-y-4" />
      </div>
      
    </div>
  </div>
</section>
