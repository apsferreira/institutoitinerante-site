---
interface Props {
  t: any;
}
const { t } = Astro.props;
---

<section id="attend-agent" class="py-24" style="background: #F5F8FA;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-black mb-6 section-accent-title">{t.attendAgent.title}</h2>
      <p class="text-lg md:text-xl max-w-3xl mx-auto leading-relaxed" style="color: #4B6070;">{t.attendAgent.description}</p>
    </div>

    <!-- Two-column layout -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- Features column -->
      <div class="space-y-6">
        {t.attendAgent.features.map((feature: any, i: number) => (
          <div
            class="feature-card flex items-start gap-4 bg-white rounded-2xl p-6 shadow-sm border border-gray-100"
            style={`animation-delay: ${i * 0.1}s`}
          >
            <span class="text-4xl shrink-0">{feature.icon}</span>
            <div>
              <h3 class="text-lg font-bold mb-1" style="color: #0D1B26;">{feature.title}</h3>
              <p class="text-sm leading-relaxed" style="color: #4B6070;">{feature.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Chat mockup column -->
      <div class="flex justify-center lg:justify-end">
        <div class="chat-phone w-full max-w-sm">
          <!-- Phone frame -->
          <div class="bg-gray-800 rounded-3xl p-3 shadow-2xl">
            <!-- Status bar -->
            <div class="bg-[#075E54] rounded-2xl overflow-hidden">
              <!-- WA Header -->
              <div class="flex items-center gap-3 px-4 py-3 bg-[#075E54]">
                <div class="w-9 h-9 rounded-full bg-[#25D366] flex items-center justify-center text-white font-bold text-sm shrink-0">
                  IIT
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-white font-semibold text-sm truncate">Attend-Agent IIT</p>
                  <p class="text-green-200 text-xs">online</p>
                </div>
                <svg class="w-5 h-5 text-white opacity-80 shrink-0" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/>
                </svg>
              </div>
              <!-- Messages area -->
              <div class="bg-[#ECE5DD] px-3 py-4 space-y-3 min-h-[300px]" style="background-image: url('data:image/svg+xml,%3Csvg width=\'20\' height=\'20\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3C/svg%3E')">
                {t.attendAgent.chatMockup.map((msg: any, i: number) => (
                  <div class={`flex ${msg.from === 'user' ? 'justify-end' : 'justify-start'} chat-bubble`} style={`animation-delay: ${0.5 + i * 0.3}s`}>
                    <div
                      class={`max-w-[78%] px-3 py-2 rounded-xl shadow-sm text-sm leading-relaxed ${
                        msg.from === 'user'
                          ? 'bg-[#DCF8C6] text-gray-800 rounded-br-none'
                          : 'bg-white text-gray-800 rounded-bl-none'
                      }`}
                    >
                      {msg.text}
                      <span class="block text-right text-[10px] text-gray-400 mt-1">
                        {msg.from === 'user' ? '✓✓' : ''}
                      </span>
                    </div>
                  </div>
                ))}
              </div>
              <!-- Input area -->
              <div class="flex items-center gap-2 px-3 py-3 bg-[#F0F0F0]">
                <div class="flex-1 bg-white rounded-full px-4 py-2 text-xs text-gray-400">Digite uma mensagem</div>
                <div class="w-9 h-9 rounded-full bg-[#25D366] flex items-center justify-center shrink-0">
                  <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
                  </svg>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center mt-16">
      <a
        href="https://wa.me/5571992732430"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 bg-[#0097D6] hover:bg-[#007ab8] text-white font-bold px-12 py-5 rounded-xl text-lg shadow-lg shadow-[#0097D6]/30 transition-all duration-200 hover:scale-105"
      >
        <svg class="w-6 h-6 shrink-0" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        {t.attendAgent.cta}
      </a>
    </div>
  </div>
</section>

<style>
  .section-accent-title {
    color: #0D1B26;
    position: relative;
    display: inline-block;
    padding-bottom: 12px;
  }
  .section-accent-title::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 60px;
    height: 4px;
    background: #0097D6;
    border-radius: 2px;
  }

  .feature-card {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .feature-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 30px rgba(0, 151, 214, 0.1);
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .chat-bubble {
    opacity: 0;
    animation: fadeInUp 0.4s ease forwards;
  }
</style>
