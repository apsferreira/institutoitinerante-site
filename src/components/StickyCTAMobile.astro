---
// StickyCTAMobile — barra fixa no fundo do mobile com CTA principal
// Visível apenas em dispositivos mobile (< lg)
// Oculta automaticamente quando o hero CTA está visível
---

<div id="sticky-cta-mobile" class="sticky-cta-mobile" aria-hidden="true" role="complementary">
  <div class="sticky-cta-inner">
    <div class="flex-1 min-w-0">
      <p class="text-white font-bold text-sm leading-tight">Brio IIT</p>
      <p class="text-blue-200 text-xs leading-tight">Ative agora — 24h sem equipe</p>
    </div>
    <a
      href="https://wa.me/5571992732430"
      target="_blank"
      rel="noopener noreferrer"
      class="sticky-cta-btn shrink-0"
      onclick="this.closest('#sticky-cta-mobile').setAttribute('aria-hidden','true')"
    >
      <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      Falar agora
    </a>
  </div>
</div>

<style>
  .sticky-cta-mobile {
    display: none; /* esconde no desktop via media query abaixo */
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 50;
    transform: translateY(100%);
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
    /* Safe area para iPhones com home bar */
    padding-bottom: env(safe-area-inset-bottom);
  }

  .sticky-cta-mobile.visible {
    transform: translateY(0);
  }

  .sticky-cta-inner {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    background: linear-gradient(135deg, #0D1B26 0%, #0d2740 100%);
    border-top: 1px solid rgba(0, 151, 214, 0.3);
    box-shadow: 0 -4px 24px rgba(0, 0, 0, 0.3);
  }

  .sticky-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #0097D6;
    color: white;
    font-weight: 700;
    font-size: 0.875rem;
    padding: 10px 18px;
    border-radius: 10px;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.2s ease, transform 0.2s ease;
    box-shadow: 0 4px 16px rgba(0, 151, 214, 0.4);
  }

  .sticky-cta-btn:active {
    transform: scale(0.97);
    background: #007ab8;
  }

  /* Apenas mobile */
  @media (max-width: 1023px) {
    .sticky-cta-mobile {
      display: block;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .sticky-cta-mobile {
      transition: none;
    }
  }
</style>

<script>
  const stickyCTA = document.getElementById('sticky-cta-mobile');
  if (stickyCTA) {
    // Mostrar após rolar além do hero (~100vh)
    const showThreshold = window.innerHeight * 0.9;
    // Observar o CTA do hero para ocultar quando visível
    const heroCTA = document.querySelector('.hero-section a[href*="wa.me"]');

    let ticking = false;

    function updateVisibility() {
      if (!stickyCTA) return;
      const scrollY = window.scrollY;

      if (scrollY > showThreshold) {
        // Verificar se o CTA do hero está visível
        if (heroCTA) {
          const rect = heroCTA.getBoundingClientRect();
          const heroVisible = rect.top >= 0 && rect.bottom <= window.innerHeight;
          if (heroVisible) {
            stickyCTA.classList.remove('visible');
            return;
          }
        }
        stickyCTA.classList.add('visible');
        stickyCTA.setAttribute('aria-hidden', 'false');
      } else {
        stickyCTA.classList.remove('visible');
        stickyCTA.setAttribute('aria-hidden', 'true');
      }
      ticking = false;
    }

    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(updateVisibility);
        ticking = true;
      }
    }, { passive: true });
  }
</script>
