---
interface Props {
  t: any;
}
const { t } = Astro.props;

const isEn = t.lang === 'en';
const homeLink = isEn ? '/en/' : '/';
const contactLink = isEn ? '/en/contact' : '/contato';
const pricingLink = isEn ? '/en/pricing' : '/precos';
const blogLink = isEn ? '/en/blog' : '/blog';
const parceirosLink = '/parceiros';
---

<footer class="bg-[#0A0F14] text-gray-400" style="border-top: 2px solid #0097D6;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
      <!-- Brand column -->
      <div class="space-y-4 md:col-span-1">
        <img
          src="/logo-iit-white.png"
          alt="Instituto Itinerante de Tecnologia"
          width="168"
          height="48"
          loading="lazy"
          class="h-12 w-auto"
        />
        <p class="text-sm leading-relaxed text-gray-400 max-w-xs">{t.footer.tagline}</p>
        <p class="text-xs text-gray-600">{t.footer.madeIn}</p>
      </div>

      <!-- Produto -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">{isEn ? 'Product' : 'Produto'}</h3>
        <ul class="space-y-2">
          <li><a href={`${homeLink}#attend-agent`} class="text-sm hover:text-[#0097D6] transition-colors">Attend-Agent</a></li>
          <li><a href={`${homeLink}#como-funciona`} class="text-sm hover:text-[#0097D6] transition-colors">{isEn ? 'How it works' : 'Como funciona'}</a></li>
          <li><a href={pricingLink} class="text-sm hover:text-[#0097D6] transition-colors">{isEn ? 'Pricing' : 'Preços'}</a></li>
          <li><a href={blogLink} class="text-sm hover:text-[#0097D6] transition-colors">Blog</a></li>
          <li><a href={parceirosLink} class="text-sm hover:text-[#0097D6] transition-colors">{isEn ? 'Partners' : 'Parceiros'}</a></li>
        </ul>
      </div>

      <!-- Segmentos -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">{isEn ? 'Segments' : 'Segmentos'}</h3>
        <ul class="space-y-2">
          <li><a href="/para/clinicas" class="text-sm hover:text-[#0097D6] transition-colors">{isEn ? 'Clinics' : 'Clínicas'}</a></li>
          <li><a href="/para/academias" class="text-sm hover:text-[#0097D6] transition-colors">{isEn ? 'Gyms' : 'Academias'}</a></li>
          <li><a href="/para/saloes" class="text-sm hover:text-[#0097D6] transition-colors">{isEn ? 'Beauty Salons' : 'Salões de Beleza'}</a></li>
          <li><a href="/para/imobiliarias" class="text-sm hover:text-[#0097D6] transition-colors">{isEn ? 'Real Estate' : 'Imobiliárias'}</a></li>
        </ul>
      </div>

      <!-- Contact column -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">{t.footer.contact.title}</h3>
        <ul class="space-y-3">
          <li>
            <a
              href="https://wa.me/5571992732430"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 text-sm hover:text-[#25D366] transition-colors duration-200"
            >
              <svg class="w-4 h-4 shrink-0 text-[#25D366]" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              +55 71 99273-2430
            </a>
          </li>
          <li>
            <a
              href="mailto:contato@institutoitinerante.com.br"
              class="flex items-center gap-2 text-sm hover:text-[#0097D6] transition-colors duration-200"
            >
              <svg class="w-4 h-4 shrink-0 text-[#0097D6]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              contato@institutoitinerante.com.br
            </a>
          </li>
          <li>
            <a
              href="https://linkedin.com/in/apsferreira"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 text-sm hover:text-[#0097D6] transition-colors duration-200"
            >
              <svg class="w-4 h-4 shrink-0 text-[#0097D6]" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              LinkedIn
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-gray-800 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-xs text-gray-600">{t.footer.rights}</p>
      <div class="flex gap-4 text-xs text-gray-600">
        <a href="/parceiros" class="hover:text-[#0097D6] transition-colors">{isEn ? 'Partners' : 'Parceiros'}</a>
        <span>·</span>
        <a href={contactLink} class="hover:text-[#0097D6] transition-colors">{isEn ? 'Contact' : 'Contato'}</a>
      </div>
    </div>
  </div>
</footer>
