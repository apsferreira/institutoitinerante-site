---
interface Props {
  t: any;
  darkHero?: boolean;
}
const { t, darkHero = true } = Astro.props;
const isEn = t.lang === 'en';
const base = isEn ? '/en' : '';
---

<header class:list={["fixed top-0 left-0 right-0 z-50 transition-all duration-300", !darkHero && "nav-scrolled"]} id="main-nav" data-dark-hero={darkHero ? "true" : "false"}>
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
    <a href={isEn ? '/en/' : '/'} class="flex items-center gap-2 shrink-0">
      <img
        id="nav-logo"
        src={darkHero ? "/logo-iit-white.png" : "/logo-iit.png"}
        alt="Instituto Itinerante de Tecnologia"
        width="168"
        height="48"
        loading="eager"
        class="h-12 w-auto transition-opacity duration-300"
      />
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-6">
      <a href={isEn ? '/en/' : '/'} class="nav-link text-sm font-medium nav-text transition-colors">Início</a>
      <a href={isEn ? '/en/solucoes' : '/solucoes'} class="nav-link text-sm font-medium nav-text transition-colors">Soluções</a>

      <!-- Produtos dropdown -->
      <div class="relative group">
        <button class="nav-link text-sm font-medium nav-text transition-colors flex items-center gap-1">
          Produtos
          <svg class="w-3 h-3 opacity-60 group-hover:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div class="absolute top-full left-1/2 -translate-x-1/2 mt-2 w-52 bg-white rounded-xl shadow-lg border border-gray-100 py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
          <a href="/brio" class="flex items-center gap-3 px-4 py-2.5 hover:bg-[#0097D6]/5 transition-colors">
            <span class="w-2 h-2 rounded-full bg-[#0097D6] shrink-0"></span>
            <div>
              <p class="text-sm font-semibold text-[#0D1B26]">Brio</p>
              <p class="text-xs text-gray-400">Atendimento 24/7</p>
            </div>
          </a>
          <a href="/focus-hub" class="flex items-center gap-3 px-4 py-2.5 hover:bg-[#00D6A0]/5 transition-colors">
            <span class="w-2 h-2 rounded-full bg-[#00D6A0] shrink-0"></span>
            <div>
              <p class="text-sm font-semibold text-[#0D1B26]">Nitro</p>
              <p class="text-xs text-gray-400">Produtividade</p>
            </div>
          </a>
          <a href="/my-library" class="flex items-center gap-3 px-4 py-2.5 hover:bg-amber-50 transition-colors">
            <span class="w-2 h-2 rounded-full bg-amber-500 shrink-0"></span>
            <div>
              <p class="text-sm font-semibold text-[#0D1B26]">Libri</p>
              <p class="text-xs text-gray-400">Conhecimento</p>
            </div>
          </a>
        </div>
      </div>

      <a href={isEn ? '/en/blog' : '/blog'} class="nav-link text-sm font-medium nav-text transition-colors">Blog</a>
      <a href={t.nav.langLink} class="text-xl transition-colors nav-text">{isEn ? '🇧🇷' : '🇺🇸'}</a>
      <a href={t.nav.contactPage} class="nav-link text-sm font-medium text-white bg-[#0097D6] hover:bg-[#007ab8] px-4 py-2.5 rounded-lg transition-colors flex items-center">{t.nav.contact}</a>
    </div>

    <!-- Mobile menu button -->
    <button id="menu-btn" class="md:hidden p-2 rounded-md nav-text" aria-label="Menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-gray-100 bg-white px-4 py-4 space-y-3">
    <a href={isEn ? '/en/' : '/'} class="block text-sm font-medium text-gray-600 hover:text-[#0097D6]">Início</a>
    <a href={isEn ? '/en/solucoes' : '/solucoes'} class="block text-sm font-medium text-gray-600 hover:text-[#0097D6]">Soluções</a>
    <div class="pl-3 border-l-2 border-gray-100 space-y-2">
      <p class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-1">Produtos</p>
      <a href="/brio" class="block text-sm font-medium text-gray-600 hover:text-[#0097D6]">Brio</a>
      <a href="/focus-hub" class="block text-sm font-medium text-[#00D6A0] hover:text-[#00A87E]">Nitro</a>
      <a href="/my-library" class="block text-sm font-medium text-amber-600 hover:text-amber-700">Libri</a>
    </div>
    <a href={isEn ? '/en/blog' : '/blog'} class="block text-sm font-medium text-gray-600 hover:text-[#0097D6]">Blog</a>
    <a href={t.nav.langLink} class="block text-xl transition-colors">{isEn ? '🇧🇷' : '🇺🇸'}</a>
    <a href={t.nav.contactPage} class="block text-sm font-medium text-white bg-[#0097D6] px-4 py-2 rounded-lg text-center">{t.nav.contact}</a>
  </div>
</header>

<style>
  /* Estado inicial: transparente (sobre hero escuro) */
  #main-nav {
    background: transparent;
  }
  #main-nav .nav-text {
    color: rgba(255, 255, 255, 0.85);
  }
  #main-nav .nav-text:hover {
    color: #0097D6;
  }

  /* Estado scrollado: fundo branco */
  #main-nav.nav-scrolled {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    box-shadow: 0 2px 20px rgba(0, 0, 0, 0.08);
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
  }
  #main-nav.nav-scrolled .nav-text {
    color: #4B5563;
  }
  #main-nav.nav-scrolled .nav-text:hover {
    color: #0097D6;
  }
</style>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  const nav = document.getElementById('main-nav');
  const logo = document.getElementById('nav-logo') as HTMLImageElement | null;

  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    // Quando o menu mobile abre, forçar fundo branco
    if (menu && !menu.classList.contains('hidden')) {
      nav?.classList.add('nav-scrolled');
      if (logo) logo.src = '/logo-iit.png';
    }
  });

  // Scroll: transparente no topo, branco ao descer
  const isDarkHero = nav?.dataset.darkHero === 'true';
  if (nav && logo) {
    if (isDarkHero) {
      const onScroll = () => {
        if (window.scrollY > 60) {
          nav.classList.add('nav-scrolled');
          logo.src = '/logo-iit.png';
        } else {
          nav.classList.remove('nav-scrolled');
          logo.src = '/logo-iit-white.png';
        }
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    }
    // When darkHero=false, nav-scrolled is always on (set in HTML)
  }
</script>
