---
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  lang?: string;
  canonical?: string;
  ogImage?: string;
  alternatePt?: string;
  alternateEn?: string;
  schemaExtra?: object | object[];
}

const {
  title,
  description,
  lang = 'pt-BR',
  canonical = Astro.url.href,
  ogImage = '/og-image.svg',
  alternatePt,
  alternateEn,
  schemaExtra,
} = Astro.props;

const siteUrl = 'https://institutoitinerante.com.br';
const ogImageUrl = `${siteUrl}${ogImage}`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Instituto Itinerante de Tecnologia',
  url: siteUrl,
  logo: `${siteUrl}/logo-iit.png`,
  description: 'Agentes de IA para empresas. Atendimento 24/7 no WhatsApp, qualificação de leads e agendamento automático.',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Salvador',
    addressRegion: 'BA',
    addressCountry: 'BR',
  },
  sameAs: [
    'https://linkedin.com/in/apsferreira',
    'https://github.com/apsferreira',
  ],
};

const whatsappLabel = lang === 'en' ? 'Talk to us' : 'Fale conosco';
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/svg+xml" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Instituto Itinerante de Tecnologia" />
    <meta property="og:locale" content={lang === 'en' ? 'en_US' : 'pt_BR'} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/logo-iit-symbol.png" />

    <!-- Schema.org JSON-LD: Organization -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Schema.org JSON-LD: Extra (per-page) -->
    {schemaExtra && <script type="application/ld+json" set:html={JSON.stringify(schemaExtra)} />}

    <!-- Hreflang -->
    {alternatePt && <link rel="alternate" hreflang="pt-BR" href={alternatePt} />}
    {alternateEn && <link rel="alternate" hreflang="en" href={alternateEn} />}
    <link rel="alternate" hreflang="x-default" href={alternatePt ?? Astro.url.href} />

    <!-- =====================================================
         TODO: Google Analytics 4
         Substituir G-XXXXXXXXXX pelo ID real do GA4
         Criar propriedade em: https://analytics.google.com/
         ===================================================== -->
    <!-- <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-XXXXXXXXXX');
    </script> -->

    <!-- =====================================================
         TODO: Microsoft Clarity
         Substituir CLARITY_ID pelo ID real do projeto Clarity
         Criar em: https://clarity.microsoft.com/
         ===================================================== -->
    <!-- <script>
      (function(c,l,a,r,i,t,y){c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
      t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
      y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "CLARITY_ID");
    </script> -->
  </head>
  <body class="min-h-screen bg-white text-gray-900 antialiased">
    <slot />

    <!-- WhatsApp floating button -->
    <a
      href="https://wa.me/5571992732430"
      target="_blank"
      rel="noopener noreferrer"
      aria-label={whatsappLabel}
      class="fixed bottom-6 right-6 z-50 flex items-center gap-2 bg-[#25D366] text-white px-4 py-3 rounded-full shadow-lg hover:shadow-xl hover:scale-105 transition-all duration-200 font-semibold"
    >
      <svg class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 24 24">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      {whatsappLabel}
    </a>
  </body>
</html>
