---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Brio from '../components/Brio.astro';
import SchemaProduct from '../components/SchemaProduct.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Cases from '../components/Cases.astro';
import Integrations from '../components/Integrations.astro';
import ContactSection from '../components/ContactSection.astro';
import Footer from '../components/Footer.astro';
import AnimatedCounters from '../components/AnimatedCounters.astro';
import { pt as t } from '../i18n/pt';
import { fetchProductsWithPrices, formatPrice } from '../lib/catalog';

// ── Busca preços do Brio na API do catálogo ────────────────────────────
const BRIO_FALLBACK_CENTS = 29700; // R$ 297/mês
const ENTERPRISE_FALLBACK_CENTS = 149700; // R$ 1.497/mês

let brioPrice = formatPrice(BRIO_FALLBACK_CENTS);
let brioInterval = '/mês';
let enterprisePrice = formatPrice(ENTERPRISE_FALLBACK_CENTS);
let enterpriseInterval = '/mês';

try {
  const products = await fetchProductsWithPrices('plan');

  const brioProduct = products.find((p) => p.name.toLowerCase() === 'brio');
  if (brioProduct) {
    const monthly = brioProduct.prices.find((pr) => pr.interval === 'monthly') ?? brioProduct.prices[0];
    if (monthly) {
      brioPrice = formatPrice(monthly.amount_cents);
      brioInterval = monthly.interval === 'yearly' ? '/ano' : monthly.interval === 'once' ? ' único' : '/mês';
    }
  }

  const enterpriseProduct = products.find((p) => p.name.toLowerCase().includes('enterprise'));
  if (enterpriseProduct) {
    const monthly = enterpriseProduct.prices.find((pr) => pr.interval === 'monthly') ?? enterpriseProduct.prices[0];
    if (monthly) {
      enterprisePrice = formatPrice(monthly.amount_cents);
      enterpriseInterval = monthly.interval === 'yearly' ? '/ano' : monthly.interval === 'once' ? ' único' : '/mês';
    }
  }
} catch {
  // Mantém fallback
}

const brioFeatures = [
  'Atendimento automatizado 24h/7',
  'Qualificação e captação de leads no WhatsApp',
  'Agendamento inteligente integrado à sua agenda',
  'Respostas personalizadas com a voz da sua marca',
  'Dashboard de conversas e métricas',
  'Configuração e onboarding inclusos',
  'Suporte técnico prioritário',
];

const enterpriseFeatures = [
  'Tudo do plano Brio, mais:',
  'Múltiplos números de WhatsApp',
  'Integrações customizadas (CRM, ERP)',
  'SLA garantido com uptime 99,9%',
  'Gerente de conta dedicado',
  'Treinamento completo da equipe',
  'Relatórios e dashboards personalizados',
  'Compliance e segurança avançados',
];
---

<BaseLayout
  title="Brio — Atendimento Inteligente 24/7 via WhatsApp | IIT"
  description="O Brio é o agente de atendimento com IA do IIT. Qualifica leads, agenda reuniões e responde clientes automaticamente no WhatsApp, 24 horas por dia."
  lang="pt-BR"
  canonical="https://institutoitinerante.com.br/brio"
>
  <SchemaProduct />
  <Nav t={t} darkHero={false} />
  <main>
    <!-- Hero Brio -->
    <section class="pt-32 pb-24" style="background: linear-gradient(135deg, #F5F8FA 0%, #EFF6FB 100%);">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <span class="inline-block text-sm font-semibold uppercase tracking-widest mb-4 text-[#0097D6]">Produto IIT</span>
        <h1 class="text-5xl md:text-6xl font-black text-[#0D1B26] mb-4 leading-tight">Brio</h1>
        <p class="text-2xl font-semibold text-[#0097D6] mb-6">Atendimento inteligente 24/7 via WhatsApp</p>
        <p class="text-xl text-[#4B6070] max-w-2xl mx-auto mb-10">
          Seu agente de IA que qualifica leads, agenda reuniões e responde clientes automaticamente — sem contratar mais ninguém.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="https://wa.me/5571992732430"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-3 bg-[#0097D6] hover:bg-[#007ab8] text-white font-bold px-10 py-4 rounded-xl shadow-lg shadow-[#0097D6]/30 transition-all hover:scale-105"
          >
            <svg class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/>
            </svg>
            Quero o Brio para minha empresa
          </a>
          <a href="#planos" class="inline-flex items-center gap-2 border-2 border-[#0097D6] text-[#0097D6] hover:bg-[#0097D6]/5 font-bold px-8 py-4 rounded-xl transition-all">
            Ver planos
          </a>
        </div>
      </div>
    </section>

    <AnimatedCounters />

    <div id="como-funciona">
      <HowItWorks />
    </div>

    <Brio t={t} />

    <Cases />
    <Integrations />

    <!-- ── Planos e Preços ───────────────────────────────────────────── -->
    <section id="planos" class="py-24 bg-white">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-14 reveal">
          <span class="inline-block text-sm font-semibold uppercase tracking-widest mb-3 text-[#0097D6]">Investimento</span>
          <h2 class="text-4xl md:text-5xl font-black text-[#0D1B26] mb-4">Planos Brio</h2>
          <p class="text-lg text-[#4B6070] max-w-xl mx-auto">
            Escolha o plano ideal para o porte e volume de atendimentos da sua empresa.
          </p>
        </div>

        <div class="reveal grid md:grid-cols-2 gap-8 items-start">

          <!-- ── Card Brio (Profissional) ── -->
          <div class="bg-white rounded-2xl border-2 border-[#0097D6] shadow-2xl shadow-[#0097D6]/10 p-10 relative">
            <div class="absolute -top-4 left-1/2 -translate-x-1/2">
              <span class="bg-[#0097D6] text-white text-xs font-bold px-5 py-1.5 rounded-full uppercase tracking-wider whitespace-nowrap">
                Mais popular
              </span>
            </div>

            <div class="mb-6 pt-2">
              <h3 class="text-xl font-black text-[#0D1B26] mb-1">Brio</h3>
              <p class="text-sm text-[#8A9FAF]">Para PMEs que querem automatizar o atendimento</p>
            </div>

            <div class="mb-8">
              <div class="text-sm text-[#8A9FAF] mb-1">a partir de</div>
              <div class="flex items-end gap-1">
                <span class="text-5xl font-black text-[#0097D6] leading-none">{brioPrice}</span>
                <span class="text-[#4B6070] pb-1 text-lg">{brioInterval}</span>
              </div>
              <p class="text-xs text-[#8A9FAF] mt-1.5">Varia conforme volume de atendimentos</p>
            </div>

            <ul class="space-y-3 mb-10">
              {brioFeatures.map((feature) => (
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-[#0097D6] shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                  <span class="text-sm text-[#4B6070] leading-snug">{feature}</span>
                </li>
              ))}
            </ul>

            <div class="space-y-3">
              <a
                href="https://wa.me/5571992732430"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center justify-center gap-3 w-full bg-[#0097D6] hover:bg-[#007ab8] text-white font-bold py-4 px-6 rounded-xl shadow-lg shadow-[#0097D6]/30 transition-all hover:scale-[1.02]"
              >
                <svg class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/>
                </svg>
                Quero o Brio agora
              </a>
              <a
                href="/contato"
                class="flex items-center justify-center w-full border-2 border-[#D0DDE6] text-[#4B6070] hover:border-[#0097D6] hover:text-[#0097D6] font-semibold py-3.5 px-6 rounded-xl transition-all text-sm"
              >
                Falar com um especialista
              </a>
            </div>
          </div>

          <!-- ── Card Enterprise ── -->
          <div class="bg-[#0D1B26] rounded-2xl border-2 border-[#00D6A0] shadow-2xl shadow-[#00D6A0]/10 p-10 relative">
            <div class="absolute -top-4 left-1/2 -translate-x-1/2">
              <span class="bg-[#00D6A0] text-[#0D1B26] text-xs font-bold px-5 py-1.5 rounded-full uppercase tracking-wider whitespace-nowrap">
                Enterprise
              </span>
            </div>

            <div class="mb-6 pt-2">
              <h3 class="text-xl font-black text-white mb-1">Brio Enterprise</h3>
              <p class="text-sm text-[#8A9FAF]">Para empresas com operações de alto volume</p>
            </div>

            <div class="mb-8">
              <div class="inline-flex items-center gap-2 bg-[#00D6A0]/10 border border-[#00D6A0]/20 rounded-xl px-4 py-2.5 mb-4">
                <svg class="w-4 h-4 text-[#00D6A0] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                </svg>
                <span class="text-[#00D6A0] font-bold text-sm">Proposta personalizada</span>
              </div>
              <p class="text-sm text-[#8A9FAF] leading-relaxed">
                Cada operação enterprise é única. Avaliamos seu volume, canais de atendimento e necessidades antes de apresentar uma proposta sob medida — com suporte dedicado, SLA diferenciado e implantação assistida.
              </p>
            </div>

            <ul class="space-y-3 mb-10">
              {enterpriseFeatures.map((feature, i) => (
                <li class="flex items-start gap-3">
                  <svg class={`w-5 h-5 shrink-0 mt-0.5 ${i === 0 ? 'text-[#8A9FAF]' : 'text-[#00D6A0]'}`} fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                  <span class={`text-sm leading-snug ${i === 0 ? 'text-[#8A9FAF] italic' : 'text-[#C8D8E4]'}`}>{feature}</span>
                </li>
              ))}
            </ul>

            <div class="space-y-3">
              <a
                href="/contato"
                class="flex items-center justify-center gap-3 w-full bg-[#00D6A0] hover:bg-[#00b888] text-[#0D1B26] font-bold py-4 px-6 rounded-xl shadow-lg shadow-[#00D6A0]/20 transition-all hover:scale-[1.02]"
              >
                Solicitar proposta personalizada
              </a>
              <a
                href="https://wa.me/5571992732430?text=Ol%C3%A1%2C%20gostaria%20de%20saber%20mais%20sobre%20o%20Brio%20Enterprise"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center justify-center gap-3 w-full border-2 border-[#1E3545] text-[#8A9FAF] hover:border-[#00D6A0] hover:text-[#00D6A0] font-semibold py-3.5 px-6 rounded-xl transition-all text-sm"
              >
                <svg class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/>
                </svg>
                Falar pelo WhatsApp
              </a>
            </div>
          </div>

        </div>

        <!-- Garantia -->
        <p class="text-center text-sm text-[#8A9FAF] mt-10">
          🔒 Sem fidelidade · Cancele quando quiser · Setup incluído em todos os planos
        </p>
      </div>
    </section>

    <ContactSection t={t} />
  </main>
  <Footer t={t} />
</BaseLayout>
