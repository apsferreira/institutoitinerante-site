---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { pt as t } from '../../i18n/pt';

const pains = [
  { icon: '💸', title: 'Interessados que somem sem matricular', desc: 'Pessoas perguntam preço no WhatsApp e você demora a responder — elas vão para a academia do lado.' },
  { icon: '📵', title: 'Sem resposta fora do horário de pico', desc: 'A maioria dos contatos chega à noite ou no fim de semana, quando sua equipe não está disponível.' },
  { icon: '🔄', title: 'Processo de matrícula manual e lento', desc: 'Coletar dados, enviar planos, agendar visita — tudo manualmente, consumindo tempo da equipe.' },
  { icon: '📉', title: 'Taxa de conversão baixa de leads', desc: 'Sem follow-up automático, os interessados esquecem e você perde a janela de conversão.' },
];

const solutions = [
  { icon: '⚡', title: 'Responde em segundos, 24/7', desc: 'Nenhum lead fica sem resposta. O agente qualifica, informa planos e agenda visita automaticamente.' },
  { icon: '🎯', title: 'Qualifica e filtra interessados', desc: 'Descobre objetivo, modalidade preferida e orçamento antes de chegar para sua equipe.' },
  { icon: '📅', title: 'Agenda visitas automáticas', desc: 'O interessado escolhe horário disponível e agenda direto — sem troca de mensagens manual.' },
  { icon: '📲', title: 'Follow-up automático', desc: 'Reengaja leads que não responderam, aumentando a taxa de conversão em até 40%.' },
];
---

<BaseLayout
  title="Brio para Academias | IIT"
  description="Automatize o atendimento da sua academia no WhatsApp. Converta mais interessados em alunos com IA 24/7, sem contratar mais atendentes."
  lang="pt-BR"
  canonical="https://institutoitinerante.com.br/para/academias"
>
  <Nav t={t} />
  <main class="pt-16">
    <section class="py-24" style="background: linear-gradient(135deg, #0A0F14 0%, #0D1B26 100%);">
      <div class="max-w-4xl mx-auto px-4 text-center">
        <span class="inline-block text-sm font-semibold uppercase tracking-widest mb-4 text-[#0097D6]">Academias</span>
        <h1 class="text-5xl font-black text-white mb-6">Brio para Academias</h1>
        <p class="text-xl text-gray-400 max-w-2xl mx-auto mb-10">Converta mais interessados em alunos matriculados com atendimento automático 24/7 no WhatsApp da sua academia.</p>
        <a
          href="https://wa.me/5571992732430?text=Quero%20o%20Brio%20para%20minha%20academia"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-[#0097D6] text-white font-bold px-10 py-4 rounded-xl shadow-lg shadow-[#0097D6]/30 hover:scale-105 transition-all"
        >
          💬 Quero o Brio para minha academia
        </a>
      </div>
    </section>

    <section class="py-24 bg-white">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-4xl font-black text-[#0D1B26] mb-4">Problemas que toda academia conhece</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {pains.map((p) => (
            <div class="flex items-start gap-4 border border-[#D0DDE6] shadow-sm rounded-2xl p-6">
              <span class="text-3xl shrink-0">{p.icon}</span>
              <div>
                <h3 class="font-bold text-[#0D1B26] mb-2">{p.title}</h3>
                <p class="text-gray-600 text-sm">{p.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-24" style="background: #F5F8FA;">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-4xl font-black text-[#0D1B26] mb-4">Como o Brio resolve</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {solutions.map((s) => (
            <div class="flex items-start gap-4 bg-white border border-[#D0DDE6] shadow-sm hover:shadow-md hover:-translate-y-1 transition-all rounded-2xl p-6">
              <span class="text-3xl shrink-0">{s.icon}</span>
              <div>
                <h3 class="font-bold text-[#0D1B26] mb-2">{s.title}</h3>
                <p class="text-gray-600 text-sm">{s.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-24 text-center bg-white">
      <div class="max-w-xl mx-auto px-4">
        <h2 class="text-4xl font-black text-[#0D1B26] mb-4">Sua academia atendendo 24/7</h2>
        <p class="text-gray-500 mb-8">Em 48h seu Brio já estará convertendo interessados em alunos enquanto você foca no treino.</p>
        <a
          href="https://wa.me/5571992732430?text=Quero%20o%20Brio%20para%20minha%20academia"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-[#0097D6] text-white font-bold px-10 py-4 rounded-xl shadow-lg shadow-[#0097D6]/30 hover:scale-105 transition-all"
        >
          💬 Quero o Brio para minha academia →
        </a>
        <p class="text-xs text-gray-400 mt-4">Planos a partir de R$397/mês · Setup em até 48h · Sem fidelidade</p>
      </div>
    </section>
  </main>
  <Footer t={t} />
</BaseLayout>
