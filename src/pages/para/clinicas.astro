---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { pt as t } from '../../i18n/pt';

const schema = {
  "@context": "https://schema.org",
  "@type": "MedicalBusiness",
  "name": "Brio para Clínicas",
  "description": "Automatize o atendimento da sua clínica ou consultório no WhatsApp com IA 24/7.",
  "url": "https://institutoitinerante.com.br/para/clinicas",
  "provider": {
    "@type": "Organization",
    "name": "Instituto Itinerante de Tecnologia",
    "url": "https://institutoitinerante.com.br"
  }
};

const pains = [
  { icon: '😰', title: 'Pacientes sem resposta fora do horário', desc: 'Clínicas perdem até 40% dos agendamentos por não responder mensagens recebidas à noite ou fim de semana.' },
  { icon: '📱', title: 'Recepcionista sobrecarregada', desc: 'Sua equipe gasta horas respondendo as mesmas dúvidas básicas sobre preços, convênios e horários.' },
  { icon: '📅', title: 'Agenda com horários vazios', desc: 'Pacientes que não conseguem agendar facilmente escolhem outra clínica.' },
  { icon: '🔄', title: 'Confirmações manuais que dão trabalho', desc: 'Ligar para confirmar consulta de cada paciente consome tempo e ainda assim há faltas.' },
];

const solutions = [
  { icon: '🕐', title: 'Atende 24/7 no WhatsApp', desc: 'Responde instantaneamente qualquer hora — noite, fim de semana, feriado. Zero paciente sem resposta.' },
  { icon: '📅', title: 'Agenda consultas automaticamente', desc: 'Integra com Google Agenda ou Calendly. O paciente agenda sem precisar falar com ninguém.' },
  { icon: '💊', title: 'Informa sobre convênios e preços', desc: 'Responde dúvidas sobre planos de saúde, procedimentos, valores — tudo configurado com informações da sua clínica.' },
  { icon: '📲', title: 'Confirma e lembra de consultas', desc: 'Envia lembretes automáticos e reduz até 60% das faltas sem esforço da equipe.' },
];
---

<BaseLayout
  title="Brio para Clínicas e Consultórios | IIT"
  description="Automatize o atendimento da sua clínica no WhatsApp. O Brio responde pacientes 24/7, agenda consultas e reduz faltas — sem contratar mais recepcionistas."
  lang="pt-BR"
  canonical="https://institutoitinerante.com.br/para/clinicas"
  schemaExtra={schema}
>
  <Nav t={t} />
  <main class="pt-16">
    <!-- Hero -->
    <section class="py-24" style="background: linear-gradient(135deg, #0A0F14 0%, #0D1B26 100%);">
      <div class="max-w-4xl mx-auto px-4 text-center">
        <span class="inline-block text-sm font-semibold uppercase tracking-widest mb-4 text-[#0097D6]">Clínicas e Consultórios</span>
        <h1 class="text-5xl font-black text-white mb-6">Brio para Clínicas e Consultórios</h1>
        <p class="text-xl text-gray-400 max-w-2xl mx-auto mb-10">Pare de perder pacientes para clínicas que respondem mais rápido. Atendimento automático 24/7 no WhatsApp da sua clínica.</p>
        <a
          href="https://wa.me/5571992732430?text=Quero%20o%20Brio%20para%20minha%20cl%C3%ADnica"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-[#0097D6] text-white font-bold px-10 py-4 rounded-xl shadow-lg shadow-[#0097D6]/30 hover:scale-105 transition-all"
        >
          💬 Quero o Brio para minha clínica
        </a>
      </div>
    </section>

    <!-- Dores -->
    <section class="py-24 bg-white">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-4xl font-black text-[#0D1B26] mb-4">Problemas que toda clínica conhece</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {pains.map((p) => (
            <div class="flex items-start gap-4 border border-[#D0DDE6] shadow-sm rounded-2xl p-6">
              <span class="text-3xl shrink-0">{p.icon}</span>
              <div>
                <h3 class="font-bold text-[#0D1B26] mb-2">{p.title}</h3>
                <p class="text-gray-600 text-sm">{p.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Soluções -->
    <section class="py-24" style="background: #F5F8FA;">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-4xl font-black text-[#0D1B26] mb-4">Como o Brio resolve</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {solutions.map((s) => (
            <div class="flex items-start gap-4 bg-white border border-[#D0DDE6] shadow-sm hover:shadow-md hover:-translate-y-1 transition-all rounded-2xl p-6">
              <span class="text-3xl shrink-0">{s.icon}</span>
              <div>
                <h3 class="font-bold text-[#0D1B26] mb-2">{s.title}</h3>
                <p class="text-gray-600 text-sm">{s.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-24 text-center bg-white">
      <div class="max-w-xl mx-auto px-4">
        <h2 class="text-4xl font-black text-[#0D1B26] mb-4">Pronto para transformar sua clínica?</h2>
        <p class="text-gray-500 mb-8">Em 48h seu Brio já estará respondendo pacientes enquanto você atende consultas.</p>
        <a
          href="https://wa.me/5571992732430?text=Quero%20o%20Brio%20para%20minha%20cl%C3%ADnica"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-[#0097D6] text-white font-bold px-10 py-4 rounded-xl shadow-lg shadow-[#0097D6]/30 hover:scale-105 transition-all"
        >
          💬 Quero o Brio para minha clínica →
        </a>
        <p class="text-xs text-gray-400 mt-4">Planos a partir de R$397/mês · Setup em até 48h · Sem fidelidade</p>
      </div>
    </section>
  </main>
  <Footer t={t} />
</BaseLayout>
