---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import ContactSection from '../components/ContactSection.astro';
import Footer from '../components/Footer.astro';
import { pt as t } from '../i18n/pt';
---

<BaseLayout
  title={t.pages.contact.title}
  description={t.pages.contact.description}
  lang="pt-BR"
  canonical="https://institutoitinerante.com.br/contato/"
  alternatePt="https://institutoitinerante.com.br/contato/"
  alternateEn="https://institutoitinerante.com.br/en/contact/"
>
  <Nav t={t} darkHero={false} />
  <main class="pt-24">
    <ContactSection t={t} />
  </main>
  <Footer t={t} />
</BaseLayout>
