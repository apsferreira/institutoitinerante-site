---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { pt as t } from '../../i18n/pt';

const posts = (await getCollection('blog', (entry) => entry.data.lang === 'pt'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function formatDate(d: Date) {
  return d.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' });
}
---

<BaseLayout
  title="Blog — Instituto Itinerante de Tecnologia"
  description="Artigos sobre automação de atendimento, WhatsApp Business, IA para PMEs e muito mais."
  lang="pt-BR"
  canonical="https://institutoitinerante.com.br/blog"
  alternatePt="https://institutoitinerante.com.br/blog"
>
  <Nav t={t} />
  <main class="pt-16">
    <!-- Header -->
    <section class="py-24" style="background: linear-gradient(135deg, #0A0F14 0%, #0D1B26 100%);">
      <div class="max-w-4xl mx-auto px-4 text-center">
        <span class="inline-block text-sm font-semibold uppercase tracking-widest mb-4 text-[#0097D6]">Blog</span>
        <h1 class="text-5xl font-black text-white mb-4">Insights sobre IA e atendimento</h1>
        <p class="text-xl text-gray-400 max-w-xl mx-auto">Conteúdo prático para empresas que querem crescer com automação inteligente.</p>
      </div>
    </section>

    <!-- Posts -->
    <section class="py-24 bg-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 gap-8">
          {posts.map((post) => (
            <article class="border border-[#D0DDE6] shadow-sm hover:shadow-md hover:-translate-y-1 transition-all rounded-2xl p-8">
              <div class="flex flex-wrap gap-2 mb-4">
                {post.data.tags.slice(0, 3).map((tag) => (
                  <span class="text-xs bg-[#0097D6]/10 text-[#0097D6] font-semibold px-3 py-1 rounded-full">{tag}</span>
                ))}
              </div>
              <h2 class="text-2xl font-black text-[#0D1B26] mb-3">
                <a href={`/blog/${post.slug}`} class="hover:text-[#0097D6] transition-colors">{post.data.title}</a>
              </h2>
              <p class="text-gray-600 mb-4 leading-relaxed">{post.data.description}</p>
              <div class="flex items-center justify-between">
                <span class="text-sm text-gray-400">{formatDate(post.data.pubDate)} · {post.data.author}</span>
                <a href={`/blog/${post.slug}`} class="text-sm font-bold text-[#0097D6] hover:underline">Ler artigo →</a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer t={t} />
</BaseLayout>
