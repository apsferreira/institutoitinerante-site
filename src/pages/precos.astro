---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { pt as t } from '../i18n/pt';

const plans = [
  {
    name: 'Starter',
    price: 'R$397',
    period: '/mês',
    description: 'Ideal para autônomos e micro empresas',
    featured: false,
    features: [
      '1 número WhatsApp',
      '500 conversas/mês',
      'Respostas automáticas 24/7',
      'Qualificação de leads',
      'Dashboard de métricas básico',
      'Suporte por email',
      'Setup em até 48h',
    ],
    cta: 'Começar com Starter',
  },
  {
    name: 'Growth',
    price: 'R$797',
    period: '/mês',
    description: 'Para negócios em crescimento',
    featured: true,
    badge: 'Mais popular',
    features: [
      '1 número WhatsApp',
      'Conversas ilimitadas',
      'Agendamento automático',
      'Integração Google Agenda / Calendly',
      'Qualificação avançada de leads',
      'Relatórios detalhados',
      'Suporte prioritário (WhatsApp)',
      'Setup em até 24h',
      'Treinamento da equipe',
    ],
    cta: 'Começar com Growth',
  },
  {
    name: 'Custom',
    price: 'A partir de R$1.497',
    period: '/mês',
    description: 'Para empresas com múltiplos atendentes',
    featured: false,
    features: [
      'Multi-número WhatsApp',
      'Conversas ilimitadas',
      'Integrações avançadas (CRM, ERP)',
      'Agentes especializados por departamento',
      'Relatórios personalizados',
      'SLA garantido',
      'Suporte dedicado 24/7',
      'Treinamento presencial/remoto',
      'Setup prioritário em até 12h',
    ],
    cta: 'Falar com especialista',
  },
];

const faqs = [
  { q: 'Existe fidelidade mínima?', a: 'Não. Nossos planos são mensais e você pode cancelar a qualquer momento. Acreditamos que o resultado fala por si.' },
  { q: 'O que está incluído no setup?', a: 'O setup (R$500-1.000, único) inclui: configuração do agente com informações do seu negócio, integração com seu WhatsApp Business, treinamento com suas FAQs, e acompanhamento nos primeiros 7 dias.' },
  { q: 'Posso mudar de plano depois?', a: 'Sim! Você pode fazer upgrade ou downgrade a qualquer momento. O ajuste é feito de forma proporcional no próximo ciclo.' },
  { q: 'O agente atende em outros idiomas?', a: 'Sim. O Attend-Agent pode ser configurado para atender em português, inglês e espanhol, dependendo do seu público.' },
  { q: 'Como funciona o suporte?', a: 'No plano Starter, suporte por email em até 24h. No Growth, WhatsApp com resposta em até 4h. No Custom, suporte dedicado com SLA garantido.' },
];
---

<BaseLayout
  title="Preços — Attend-Agent | Instituto Itinerante de Tecnologia"
  description="Planos do Attend-Agent a partir de R$397/mês. Atendimento automático 24/7 no WhatsApp para sua empresa. Sem fidelidade."
  lang="pt-BR"
  canonical="https://institutoitinerante.com.br/precos"
  alternatePt="https://institutoitinerante.com.br/precos"
  alternateEn="https://institutoitinerante.com.br/en/pricing"
>
  <Nav t={t} />
  <main class="pt-16">
    <!-- Hero -->
    <section class="py-24 text-center" style="background: linear-gradient(135deg, #0A0F14 0%, #0D1B26 100%);">
      <div class="max-w-4xl mx-auto px-4">
        <span class="inline-block text-sm font-semibold uppercase tracking-widest mb-4 text-[#0097D6]">Preços</span>
        <h1 class="text-5xl font-black text-white mb-4">Simples e transparente</h1>
        <p class="text-xl text-gray-400 max-w-xl mx-auto">Sem taxa escondida. Sem fidelidade. Cancele quando quiser.</p>
      </div>
    </section>

    <!-- Plans -->
    <section class="py-24 bg-white">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {plans.map((plan) => (
            <div class={`relative rounded-2xl p-8 flex flex-col ${plan.featured ? 'bg-[#0097D6] text-white shadow-2xl shadow-[#0097D6]/30 scale-105' : 'border border-[#D0DDE6] shadow-sm hover:shadow-md hover:-translate-y-1 transition-all bg-white'}`}>
              {plan.featured && plan.badge && (
                <div class="absolute -top-4 left-1/2 -translate-x-1/2">
                  <span class="bg-[#00D6A0] text-white text-xs font-black px-4 py-1.5 rounded-full uppercase tracking-wide">
                    {plan.badge}
                  </span>
                </div>
              )}
              <div class="mb-6">
                <h2 class={`text-xl font-black mb-1 ${plan.featured ? 'text-white' : 'text-[#0D1B26]'}`}>{plan.name}</h2>
                <p class={`text-sm mb-4 ${plan.featured ? 'text-white/70' : 'text-gray-500'}`}>{plan.description}</p>
                <div class="flex items-baseline gap-1">
                  <span class={`text-3xl font-black ${plan.featured ? 'text-white' : 'text-[#0D1B26]'}`}>{plan.price}</span>
                  <span class={`text-sm ${plan.featured ? 'text-white/70' : 'text-gray-500'}`}>{plan.period}</span>
                </div>
              </div>

              <ul class="space-y-3 flex-1 mb-8">
                {plan.features.map((f) => (
                  <li class={`flex items-start gap-2 text-sm ${plan.featured ? 'text-white/90' : 'text-gray-600'}`}>
                    <span class={`shrink-0 mt-0.5 ${plan.featured ? 'text-white' : 'text-[#00D6A0]'}`}>✓</span>
                    {f}
                  </li>
                ))}
              </ul>

              <a
                href="https://wa.me/5571992732430?text=Tenho%20interesse%20no%20plano%20" + plan.name
                target="_blank"
                rel="noopener noreferrer"
                class={`text-center font-bold px-6 py-3 rounded-xl transition-all hover:scale-105 ${
                  plan.featured
                    ? 'bg-white text-[#0097D6] shadow-lg'
                    : 'bg-[#0097D6] text-white shadow-lg shadow-[#0097D6]/30'
                }`}
              >
                {plan.cta}
              </a>
            </div>
          ))}
        </div>

        <!-- Setup fee note -->
        <div class="mt-12 text-center">
          <div class="inline-flex items-center gap-3 bg-amber-50 border border-amber-200 rounded-xl px-6 py-4">
            <span class="text-amber-500">⚡</span>
            <p class="text-sm text-amber-800">
              <strong>Setup único:</strong> R$500–R$1.000 (uma vez só) · Inclui configuração completa, integração e acompanhamento nos primeiros 7 dias.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-24" style="background: #F5F8FA;">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-4xl font-black text-[#0D1B26] mb-4">Dúvidas sobre preços</h2>
        </div>
        <div class="space-y-4">
          {faqs.map((faq) => (
            <details class="bg-white border border-[#D0DDE6] rounded-xl p-6 group">
              <summary class="font-bold text-[#0D1B26] cursor-pointer list-none flex items-center justify-between">
                {faq.q}
                <span class="text-[#0097D6] group-open:rotate-45 transition-transform">+</span>
              </summary>
              <p class="mt-4 text-gray-600 text-sm leading-relaxed">{faq.a}</p>
            </details>
          ))}
        </div>

        <div class="text-center mt-12">
          <p class="text-gray-500 mb-4">Ainda tem dúvidas? Fale diretamente com nossa equipe.</p>
          <a
            href="https://wa.me/5571992732430?text=Quero%20falar%20com%20um%20especialista%20sobre%20os%20planos"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 bg-[#0097D6] text-white font-bold px-8 py-4 rounded-xl shadow-lg shadow-[#0097D6]/30 hover:scale-105 transition-all"
          >
            💬 Falar com especialista
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer t={t} />
</BaseLayout>
