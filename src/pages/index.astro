---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import About from '../components/About.astro';
import Cases from '../components/Cases.astro';
import SchemaProduct from '../components/SchemaProduct.astro';
import ContactSection from '../components/ContactSection.astro';
import Footer from '../components/Footer.astro';
import SocialProofBar from '../components/SocialProofBar.astro';
import AnimatedCounters from '../components/AnimatedCounters.astro';
import StickyCTAMobile from '../components/StickyCTAMobile.astro';
import { pt as t } from '../i18n/pt';
---

<BaseLayout
  title={t.pages.home.title}
  description={t.pages.home.description}
  lang="pt-BR"
  canonical="https://institutoitinerante.com.br/"
  alternatePt="https://institutoitinerante.com.br/"
  alternateEn="https://institutoitinerante.com.br/en/"
>
  <SchemaProduct />
  <Nav t={t} />
  <StickyCTAMobile />
  <main>
    <!-- Hero institucional -->
    <section class="hero-section hero-bg-anim relative min-h-screen flex items-center justify-center pt-16 overflow-hidden">
      <!-- Circuit grid background (CSS only) -->
      <div class="hero-grid absolute inset-0 pointer-events-none"></div>
      <!-- Glow blobs -->
      <div class="absolute top-1/3 right-1/4 w-96 h-96 bg-[#0097D6]/10 rounded-full blur-3xl pointer-events-none"></div>
      <div class="absolute bottom-1/4 left-1/4 w-64 h-64 bg-[#00D6A0]/8 rounded-full blur-3xl pointer-events-none"></div>

      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 text-center">
        <span class="inline-block text-sm font-semibold uppercase tracking-widest mb-6 text-[#0097D6] fade-in-up" style="animation-delay: 0s">Produtos digitais com propósito</span>
        <h1 class="text-5xl sm:text-6xl md:text-7xl font-black text-white leading-tight tracking-tight mb-6 fade-in-up" style="animation-delay: 0.2s">
          Seu negócio funcionando<br class="hidden sm:block" />
          no <span style="color: #0097D6;">piloto automático</span>
        </h1>
        <p class="text-xl md:text-2xl max-w-3xl mx-auto mb-8 leading-relaxed fade-in-up" style="color: #8A9FAF; animation-delay: 0.28s">
          Agentes de IA que atendem, organizam e vendem por você — 24/7, sem equipe extra.
        </p>

        <!-- Credibility bar -->
        <div class="flex items-center justify-center gap-6 flex-wrap mb-10 fade-in-up" style="animation-delay: 0.35s">
          <span class="text-sm text-gray-400 flex items-center gap-2"><span class="text-[#00D6A0]">📊</span> 3 produtos</span>
          <span class="text-gray-600">·</span>
          <span class="text-sm text-gray-400 flex items-center gap-2"><span class="text-[#00D6A0]">🕐</span> 24/7</span>
          <span class="text-gray-600">·</span>
          <span class="text-sm text-gray-400 flex items-center gap-2"><span class="text-[#00D6A0]">⚡</span> &lt; 30s resposta</span>
        </div>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 fade-in-up" style="animation-delay: 0.4s">
          <a
            href="/brio"
            class="btn-pulse btn-shimmer inline-flex items-center gap-2 bg-[#0097D6] hover:bg-[#007ab8] text-white font-bold px-8 py-4 rounded-xl text-base shadow-lg shadow-[#0097D6]/30 transition-all duration-200 hover:scale-105"
          >
            Testar o Brio grátis →
          </a>
          <a
            href="#produtos"
            class="inline-flex items-center gap-2 border-2 border-white/30 text-white hover:border-[#0097D6] hover:text-[#0097D6] font-semibold px-8 py-4 rounded-xl text-base transition-all duration-200"
          >
            Ver demonstração
          </a>
        </div>

        <!-- Scroll indicator -->
        <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce">
          <svg class="w-6 h-6 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7 7" />
          </svg>
        </div>
      </div>
    </section>

    <SocialProofBar />
    <About t={t} />
    <AnimatedCounters />

    <!-- Nossos Produtos -->
    <section id="produtos" class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-black text-[#0D1B26] mb-4 section-title-accent">Nosso Ecossistema</h2>
          <p class="text-gray-500 max-w-xl mx-auto">Soluções construídas para diferentes necessidades — do atendimento ao foco e ao conhecimento.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <!-- Brio -->
          <a href="/brio" class="group bg-white rounded-2xl border border-gray-200 p-8 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300 flex flex-col">
            <div class="w-12 h-1.5 rounded-full mb-6" style="background: #0097D6;"></div>
            <span class="self-start text-xs font-semibold uppercase tracking-wider px-3 py-1 rounded-full mb-4" style="background: #0097D610; color: #0097D6;">disponível</span>
            <h3 class="text-2xl font-black mb-2 text-[#0D1B26]">Brio</h3>
            <p class="text-base leading-relaxed flex-1 text-[#4B6070]">Agente de atendimento inteligente 24/7 via WhatsApp. Qualifica leads, agenda reuniões e nunca deixa um cliente sem resposta.</p>
            <div class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-[#0097D6]">
              Saiba mais
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          </a>

          <!-- Focus Hub -->
          <a href="/focus-hub" class="group bg-white rounded-2xl border border-gray-200 p-8 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300 flex flex-col">
            <div class="w-12 h-1.5 rounded-full mb-6" style="background: #00D6A0;"></div>
            <span class="self-start text-xs font-semibold uppercase tracking-wider px-3 py-1 rounded-full mb-4" style="background: #00D6A010; color: #00A87E;">disponível</span>
            <h3 class="text-2xl font-black mb-2 text-[#0D1B26]">Focus Hub</h3>
            <p class="text-base leading-relaxed flex-1 text-[#4B6070]">Plataforma de produtividade e foco para equipes. Reduza distrações e entregue mais com menos esforço.</p>
            <div class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-[#00A87E]">
              Saiba mais
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          </a>

          <!-- My Library -->
          <a href="/my-library" class="group bg-white rounded-2xl border border-gray-200 p-8 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300 flex flex-col">
            <div class="w-12 h-1.5 rounded-full mb-6" style="background: #F59E0B;"></div>
            <span class="self-start text-xs font-semibold uppercase tracking-wider px-3 py-1 rounded-full mb-4" style="background: #F59E0B10; color: #D97706;">disponível</span>
            <h3 class="text-2xl font-black mb-2 text-[#0D1B26]">My Library</h3>
            <p class="text-base leading-relaxed flex-1 text-[#4B6070]">Sua biblioteca pessoal inteligente. Organize, pesquise e aprenda com todo o conteúdo que você consome.</p>
            <div class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-[#D97706]">
              Saiba mais
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          </a>
        </div>
      </div>
    </section>

    <Cases />
    <ContactSection t={t} />
  </main>
  <Footer t={t} />
</BaseLayout>

<style>
  .section-title-accent {
    position: relative;
    display: inline-block;
    padding-bottom: 12px;
  }
  .section-title-accent::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 60px;
    height: 4px;
    background: #0097D6;
    border-radius: 2px;
  }

  /* Hero Dark Theme Styles */
  .hero-section {
    background: linear-gradient(135deg, #080d11 0%, #0D1B26 40%, #0d2740 70%, #0D1B26 100%);
  }

  .hero-grid {
    background-image:
      linear-gradient(rgba(0, 151, 214, 0.07) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 151, 214, 0.07) 1px, transparent 1px);
    background-size: 40px 40px;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .fade-in-up {
    opacity: 0;
    animation: fadeInUp 0.6s ease forwards;
  }
</style>
