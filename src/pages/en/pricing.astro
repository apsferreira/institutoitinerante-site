---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { en as t } from '../../i18n/en';

const plans = [
  {
    name: 'Starter',
    price: 'R$397',
    period: '/mo',
    description: 'Ideal for freelancers and micro businesses',
    featured: false,
    features: [
      '1 WhatsApp number',
      '500 conversations/month',
      'Automatic 24/7 responses',
      'Lead qualification',
      'Basic metrics dashboard',
      'Email support',
      'Setup within 48h',
    ],
    cta: 'Start with Starter',
  },
  {
    name: 'Growth',
    price: 'R$797',
    period: '/mo',
    description: 'For growing businesses',
    featured: true,
    badge: 'Most popular',
    features: [
      '1 WhatsApp number',
      'Unlimited conversations',
      'Automatic scheduling',
      'Google Calendar / Calendly integration',
      'Advanced lead qualification',
      'Detailed reports',
      'Priority support (WhatsApp)',
      'Setup within 24h',
      'Team training',
    ],
    cta: 'Start with Growth',
  },
  {
    name: 'Custom',
    price: 'From R$1,497',
    period: '/mo',
    description: 'For companies with multiple attendants',
    featured: false,
    features: [
      'Multi-number WhatsApp',
      'Unlimited conversations',
      'Advanced integrations (CRM, ERP)',
      'Specialized agents per department',
      'Custom reports',
      'Guaranteed SLA',
      '24/7 dedicated support',
      'On-site/remote training',
      'Priority setup within 12h',
    ],
    cta: 'Talk to a specialist',
  },
];
---

<BaseLayout
  title="Pricing — Attend-Agent | Instituto Itinerante de Tecnologia"
  description="Attend-Agent plans from R$397/mo. 24/7 automatic WhatsApp support for your business. No lock-in."
  lang="en"
  canonical="https://institutoitinerante.com.br/en/pricing"
  alternatePt="https://institutoitinerante.com.br/precos"
  alternateEn="https://institutoitinerante.com.br/en/pricing"
>
  <Nav t={t} />
  <main class="pt-16">
    <section class="py-24 text-center" style="background: linear-gradient(135deg, #0A0F14 0%, #0D1B26 100%);">
      <div class="max-w-4xl mx-auto px-4">
        <span class="inline-block text-sm font-semibold uppercase tracking-widest mb-4 text-[#0097D6]">Pricing</span>
        <h1 class="text-5xl font-black text-white mb-4">Simple and transparent</h1>
        <p class="text-xl text-gray-400 max-w-xl mx-auto">No hidden fees. No lock-in. Cancel anytime.</p>
      </div>
    </section>

    <section class="py-24 bg-white">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {plans.map((plan) => (
            <div class={`relative rounded-2xl p-8 flex flex-col ${plan.featured ? 'bg-[#0097D6] text-white shadow-2xl shadow-[#0097D6]/30 scale-105' : 'border border-[#D0DDE6] shadow-sm hover:shadow-md hover:-translate-y-1 transition-all bg-white'}`}>
              {plan.featured && plan.badge && (
                <div class="absolute -top-4 left-1/2 -translate-x-1/2">
                  <span class="bg-[#00D6A0] text-white text-xs font-black px-4 py-1.5 rounded-full uppercase tracking-wide">
                    {plan.badge}
                  </span>
                </div>
              )}
              <h2 class={`text-xl font-black mb-1 ${plan.featured ? 'text-white' : 'text-[#0D1B26]'}`}>{plan.name}</h2>
              <p class={`text-sm mb-4 ${plan.featured ? 'text-white/70' : 'text-gray-500'}`}>{plan.description}</p>
              <div class="flex items-baseline gap-1 mb-6">
                <span class={`text-3xl font-black ${plan.featured ? 'text-white' : 'text-[#0D1B26]'}`}>{plan.price}</span>
                <span class={`text-sm ${plan.featured ? 'text-white/70' : 'text-gray-500'}`}>{plan.period}</span>
              </div>
              <ul class="space-y-3 flex-1 mb-8">
                {plan.features.map((f) => (
                  <li class={`flex items-start gap-2 text-sm ${plan.featured ? 'text-white/90' : 'text-gray-600'}`}>
                    <span class={`shrink-0 mt-0.5 ${plan.featured ? 'text-white' : 'text-[#00D6A0]'}`}>✓</span>
                    {f}
                  </li>
                ))}
              </ul>
              <a
                href="https://wa.me/5571992732430"
                target="_blank"
                rel="noopener noreferrer"
                class={`text-center font-bold px-6 py-3 rounded-xl transition-all hover:scale-105 ${plan.featured ? 'bg-white text-[#0097D6] shadow-lg' : 'bg-[#0097D6] text-white shadow-lg shadow-[#0097D6]/30'}`}
              >
                {plan.cta}
              </a>
            </div>
          ))}
        </div>
        <div class="mt-12 text-center">
          <div class="inline-flex items-center gap-3 bg-amber-50 border border-amber-200 rounded-xl px-6 py-4">
            <span class="text-amber-500">⚡</span>
            <p class="text-sm text-amber-800">
              <strong>One-time setup fee:</strong> R$500–R$1,000 · Includes full configuration, integration and 7-day follow-up.
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer t={t} />
</BaseLayout>
