---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { pt as t } from '../i18n/pt';

import HeroMyLibrary from '../components/my-library/HeroMyLibrary.astro';
import ProblemSection from '../components/my-library/ProblemSection.astro';
import SolutionSection from '../components/my-library/SolutionSection.astro';
import FeaturesSection from '../components/my-library/FeaturesSection.astro';
import SocialProofSection from '../components/my-library/SocialProofSection.astro';
import PricingSection from '../components/my-library/PricingSection.astro';
import FAQSection from '../components/my-library/FAQSection.astro';
import CTAFinal from '../components/my-library/CTAFinal.astro';
---

<BaseLayout
  title="My Library — Sua biblioteca pessoal de livros, organizada e bonita"
  description="My Library é o catálogo pessoal de livros para quem quer organizar a biblioteca, acompanhar o progresso e ler mais com consistência — sem a bagunça das redes sociais literárias."
  lang="pt-BR"
  canonical="https://institutoitinerante.com.br/my-library"
>
  <Nav t={t} darkHero={false} />
  <main>
    <HeroMyLibrary />
    <ProblemSection />
    <SolutionSection />
    <FeaturesSection />
    <SocialProofSection />
    <PricingSection />
    <FAQSection />
    <CTAFinal />
  </main>
  <Footer t={t} />
</BaseLayout>

<style is:global>
  /* Scroll-triggered fade-in for My Library sections */
  .ml-reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.65s ease, transform 0.65s ease;
  }
  .ml-reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1 }
  );

  // Observe all ml-reveal elements that are not in the hero (already animated via CSS)
  document.querySelectorAll('.ml-section .ml-reveal').forEach((el) => observer.observe(el));
</script>
